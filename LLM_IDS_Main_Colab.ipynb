   "source": [
    "# ============================================================\n",
    "# CELL 6: LLM Threat Analysis Engine (RAG + NLP Summarizer)\n",
    "# ============================================================\n",
    "import anthropic\n",
    "import openai\n",
    "import json\n",
    "import time\n",
    "\n",
    "# ── LLM Client initialization ─────────────────────────────────\n",
    "if LLM_PROVIDER == 'anthropic':\n",
    "    llm_client = anthropic.Anthropic(api_key=ANTHROPIC_API_KEY)\n",
    "    LLM_MODEL  = 'claude-haiku-4-5-20251001'  # Fast & free tier\n",
    "else:\n",
    "    llm_client = openai.OpenAI(api_key=OPENAI_API_KEY)\n",
    "    LLM_MODEL  = 'gpt-4o-mini'\n",
    "\n",
    "# ── System prompt for IDS analysis ───────────────────────────\n",
    "IDS_SYSTEM_PROMPT = \"\"\"You are an expert Network Security Analyst AI embedded in an Intrusion Detection System.\n",
    "Your role is to analyze network traffic flows and generate clear, actionable security reports.\n",
    "\n",
    "When analyzing traffic:\n",
    "1. Identify the most likely attack type based on traffic characteristics\n",
    "2. Assess threat severity (CRITICAL/HIGH/MEDIUM/LOW/NONE)\n",
    "3. Explain WHY you classified it this way (feature-based reasoning)\n",
    "4. Provide immediate recommended actions\n",
    "5. Reference relevant MITRE ATT&CK techniques\n",
    "\n",
    "Output format: JSON with fields: threat_type, severity, confidence (0-100), explanation, indicators_triggered, recommendations, mitre_technique\n",
    "Keep explanation concise (2-3 sentences). Be precise and actionable.\"\"\"\n",
    "\n",
    "def analyze_flow_with_llm(flow_data: dict, ml_prediction: str, anomaly_score: float) -> dict:\n",
    "    \"\"\"\n",
    "    Analyze a network flow using RAG + LLM.\n",
    "    \n",
    "    Args:\n",
    "        flow_data: Dictionary of flow features\n",
    "        ml_prediction: Label predicted by Random Forest\n",
    "        anomaly_score: Isolation Forest anomaly score\n",
    "    \n",
    "    Returns:\n",
    "        dict: Structured threat report\n",
    "    \"\"\"\n",
    "    # Step 1: Retrieve relevant threat context (RAG)\n",
    "    flow_description = (\n",
    "        f\"flow_bytes_per_sec={flow_data.get('flow_bytes_s', 0):.0f} \"\n",
    "        f\"packets_per_sec={flow_data.get('flow_packets_s', 0):.1f} \"\n",
    "        f\"dst_port={flow_data.get('dst_port', 0)} \"\n",
    "        f\"syn_flags={flow_data.get('syn_flag_count', 0)} \"\n",
    "        f\"fwd_packets={flow_data.get('fwd_packets', 0)}\"\n",
    "    )\n",
    "    threat_context = retrieve_threat_context(flow_description, top_k=2)\n",
    "\n",
    "    # Format context for RAG\n",
    "    context_str = \"\\n\".join([\n",
    "        f\"[Threat {i+1}] {doc['title']} (Severity: {doc['severity']})\\n\"\n",
    "        f\"  Description: {doc['description']}\\n\"\n",
    "        f\"  MITRE: {doc['mitre_technique']}\\n\"\n",
    "        f\"  Mitigation: {doc['mitigation']}\"\n",
    "        for i, doc in enumerate(threat_context)\n",
    "    ])\n",
    "\n",
    "    # Step 2: Build LLM prompt\n",
    "    user_prompt = f\"\"\"NETWORK FLOW ANALYSIS REQUEST\n",
    "\n",
    "=== TRAFFIC FEATURES ===\n",
    "Source IP:          {flow_data.get('src_ip', 'unknown')}\n",
    "Destination IP:     {flow_data.get('dst_ip', 'unknown')}\n",
    "Destination Port:   {flow_data.get('dst_port', 0)}\n",
    "Protocol:           {flow_data.get('protocol', 'TCP')}\n",
    "Flow Duration (ms): {flow_data.get('flow_duration', 0)}\n",
    "Forward Packets:    {flow_data.get('fwd_packets', 0)}\n",
    "Backward Packets:   {flow_data.get('bwd_packets', 0)}\n",
    "Bytes/Second:       {flow_data.get('flow_bytes_s', 0):.2f}\n",
    "Packets/Second:     {flow_data.get('flow_packets_s', 0):.2f}\n",
    "SYN Flags:          {flow_data.get('syn_flag_count', 0)}\n",
    "PSH Flags:          {flow_data.get('psh_flag_count', 0)}\n",
    "Packet Ratio:       {flow_data.get('packet_ratio', 0):.2f}\n",
    "\n",
    "=== ML MODEL OUTPUTS ===\n",
    "Random Forest Prediction: {ml_prediction}\n",
    "Isolation Forest Anomaly Score: {anomaly_score:.4f} (higher = more suspicious)\n",
    "\n",
    "=== RETRIEVED THREAT INTELLIGENCE (RAG Context) ===\n",
    "{context_str}\n",
    "\n",
    "Analyze this network flow and provide a structured JSON threat report.\"\"\"\n",
    "\n",
    "    # Step 3: Call LLM\n",
    "    try:\n",
    "        if LLM_PROVIDER == 'anthropic':\n",
    "            response = llm_client.messages.create(\n",
    "                model=LLM_MODEL,\n",
    "                max_tokens=500,\n",
    "                system=IDS_SYSTEM_PROMPT,\n",
    "                messages=[{\"role\": \"user\", \"content\": user_prompt}]\n",
    "            )\n",
    "            raw_text = response.content[0].text\n",
    "        else:\n",
    "            response = llm_client.chat.completions.create(\n",
    "                model=LLM_MODEL,\n",
    "                messages=[\n",
    "                    {\"role\": \"system\", \"content\": IDS_SYSTEM_PROMPT},\n",
    "                    {\"role\": \"user\",   \"content\": user_prompt}\n",
    "                ],\n",
    "                max_tokens=500\n",
    "            )\n",
    "            raw_text = response.choices[0].message.content\n",
    "\n",
    "        # Parse JSON response\n",
    "        try:\n",
    "            # Strip markdown fences if present\n",
    "            cleaned = raw_text.strip().removeprefix('```json').removeprefix('```').removesuffix('```').strip()\n",
    "            result = json.loads(cleaned)\n",
    "        except json.JSONDecodeError:\n",
    "            # Fallback if LLM returns non-JSON\n",
    "            result = {\n",
    "                \"threat_type\":         ml_prediction,\n",
    "                \"severity\":            \"HIGH\" if ml_prediction != 'BENIGN' else 'NONE',\n",
    "                \"confidence\":          75,\n",
    "                \"explanation\":         raw_text[:300],\n",
    "                \"indicators_triggered\": [],\n",
    "                \"recommendations\":     \"Investigate further.\",\n",
    "                \"mitre_technique\":     \"Unknown\"\n",
    "            }\n",
    "\n",
    "        result['raw_llm_response'] = raw_text\n",
    "        result['rag_context'] = [doc['title'] for doc in threat_context]\n",
    "        return result\n",
    "\n",
    "    except Exception as e:\n",
    "        return {\n",
    "            \"threat_type\":         ml_prediction,\n",
    "            \"severity\":            \"UNKNOWN\",\n",
    "            \"confidence\":          50,\n",
    "            \"explanation\":         f\"LLM analysis failed: {str(e)[:100]}\",\n",
    "            \"indicators_triggered\": [],\n",
    "            \"recommendations\":     \"Manual review required.\",\n",
    "            \"error\":               str(e)\n",
    "        }\n",
    "\n",
    "\n",
    "# ── Test the full RAG + LLM pipeline ─────────────────────────\n",
    "print('🧪 Testing LLM analysis pipeline on a suspicious flow...')\n",
    "print('=' * 60)\n",
    "\n",
    "# Pick a detected attack from our dataset\n",
    "attack_sample = processed_df[processed_df['label'] == 'DoS_Hulk'].iloc[0].to_dict()\n",
    "\n",
    "report = analyze_flow_with_llm(\n",
    "    flow_data      = attack_sample,\n",
    "    ml_prediction  = attack_sample['label'],\n",
    "    anomaly_score  = float(attack_sample.get('iso_anomaly_score', 0.5))\n",
    ")\n",
    "\n",
    "print(f\"🚨 THREAT TYPE:   {report.get('threat_type', 'Unknown')}\")\n",
    "print(f\"⚠️  SEVERITY:      {report.get('severity', 'Unknown')}\")\n",
    "print(f\"🎯 CONFIDENCE:    {report.get('confidence', 0)}%\")\n",
    "print(f\"\\n📝 EXPLANATION:\")\n",
    "print(f\"   {report.get('explanation', 'N/A')}\")\n",
    "print(f\"\\n🛡️  RECOMMENDATIONS:\")\n",
    "print(f\"   {report.get('recommendations', 'N/A')}\")\n",
    "print(f\"\\n🔗 MITRE ATT&CK: {report.get('mitre_technique', 'N/A')}\")\n",
    "print(f\"\\n📚 RAG Context Used: {report.get('rag_context', [])}\")"
   ]
  },
