    "---\n",
    "## 📊 STEP 7: Signature-Based IDS Comparison (Snort-style)\n",
    "*Benchmark our LLM+ML system against traditional rule-based detection*"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 7: Signature-Based IDS (Snort-style Rules) for Comparison\n",
    "# ============================================================\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.patches as mpatches\n",
    "import seaborn as sns\n",
    "\n",
    "# ── Implement Snort-inspired rule engine ──────────────────────\n",
    "class SignatureBasedIDS:\n",
    "    \"\"\"\n",
    "    Traditional signature-based IDS mimicking Snort rule logic.\n",
    "    Rules are based on CICIDS2017 published thresholds.\n",
    "    Weakness: cannot detect zero-days or novel attack variations.\n",
    "    \"\"\"\n",
    "\n",
    "    def __init__(self):\n",
    "        self.rules = [\n",
    "            # Rule ID, Description, Detection Function\n",
    "            ('SIG-001', 'DoS Hulk: HTTP Flood',\n",
    "             lambda r: r['flow_bytes_s'] > 80000 and r['fwd_packets'] > 300 and r['dst_port'] in [80, 443, 8080]),\n",
    "\n",
    "            ('SIG-002', 'DDoS: High Volume Flood',\n",
    "             lambda r: r['flow_packets_s'] > 400 and r['syn_flag_count'] > 10),\n",
    "\n",
    "            ('SIG-003', 'PortScan: Rapid Port Probe',\n",
    "             lambda r: r['flow_duration'] < 150 and r['fwd_packets'] <= 3 and r['syn_flag_count'] >= 1),\n",
    "\n",
    "            ('SIG-004', 'BruteForce: FTP Login Attempt',\n",
    "             lambda r: r['dst_port'] == 21 and r['fwd_packets'] > 4),\n",
    "\n",
    "            ('SIG-005', 'BruteForce: SSH Login Attempt',\n",
    "             lambda r: r['dst_port'] == 22 and r['fwd_packets'] > 4 and r['bwd_packets'] > 2),\n",
    "        ]\n",
    "\n",
    "    def detect(self, row):\n",
    "        \"\"\"Return triggered rule or BENIGN.\"\"\"\n",
    "        for rule_id, description, condition in self.rules:\n",
    "            try:\n",
    "                if condition(row):\n",
    "                    return 1, f\"{rule_id}: {description}\"\n",
    "            except Exception:\n",
    "                continue\n",
    "        return 0, 'BENIGN'\n",
    "\n",
    "# ── Run both systems on the same dataset ─────────────────────\n",
    "sig_ids = SignatureBasedIDS()\n",
    "sig_results = processed_df.apply(lambda row: sig_ids.detect(row.to_dict()), axis=1)\n",
    "sig_preds   = [r[0] for r in sig_results]\n",
    "\n",
    "# ML-based results (Isolation Forest)\n",
    "ml_preds = processed_df['iso_prediction'].tolist()\n",
    "y_true   = processed_df['is_attack'].tolist()\n",
    "\n",
    "# ── Compute metrics ───────────────────────────────────────────\n",
    "def compute_metrics(y_true, y_pred, name):\n",
    "    tp = sum(1 for t, p in zip(y_true, y_pred) if t == 1 and p == 1)\n",
    "    tn = sum(1 for t, p in zip(y_true, y_pred) if t == 0 and p == 0)\n",
    "    fp = sum(1 for t, p in zip(y_true, y_pred) if t == 0 and p == 1)\n",
    "    fn = sum(1 for t, p in zip(y_true, y_pred) if t == 1 and p == 0)\n",
    "\n",
    "    precision = tp / (tp + fp + 1e-9)\n",
    "    recall    = tp / (tp + fn + 1e-9)\n",
    "    f1        = 2 * precision * recall / (precision + recall + 1e-9)\n",
    "    fpr       = fp / (fp + tn + 1e-9)  # False Positive Rate\n",
    "\n",
    "    return {\n",
    "        'System':    name,\n",
    "        'Precision': round(precision, 4),\n",
    "        'Recall':    round(recall, 4),\n",
    "        'F1-Score':  round(f1, 4),\n",
    "        'FPR':       round(fpr, 4),\n",
    "        'TP': tp, 'TN': tn, 'FP': fp, 'FN': fn\n",
    "    }\n",
    "\n",
    "comparison = pd.DataFrame([\n",
    "    compute_metrics(y_true, sig_preds, 'Signature-Based IDS (Snort-style)'),\n",
    "    compute_metrics(y_true, ml_preds,  'LLM+ML IDS (Our System)'),\n",
    "])\n",
    "\n",
    "print('=' * 70)\n",
    "print('         COMPARISON: LLM+ML IDS vs Signature-Based IDS')\n",
    "print('=' * 70)\n",
    "print(comparison[['System', 'Precision', 'Recall', 'F1-Score', 'FPR']].to_string(index=False))\n",
    "\n",
    "# ── Visualization ─────────────────────────────────────────────\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
