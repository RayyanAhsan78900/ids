    "---\n",
    "## 🗄️ STEP 3: Data Loading & PySpark Processing\n",
    "*We use the CICIDS2017 dataset (standard benchmark for IDS research)*"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 3A: Initialize PySpark\n",
    "# ============================================================\n",
    "from pyspark.sql import SparkSession\n",
    "from pyspark.sql import functions as F\n",
    "from pyspark.sql.types import *\n",
    "from pyspark.ml.feature import VectorAssembler, StandardScaler\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "# Create Spark session optimized for Colab\n",
    "spark = SparkSession.builder \\\n",
    "    .appName('LLM_IDS_UMT_2026') \\\n",
    "    .config('spark.driver.memory', '4g') \\\n",
    "    .config('spark.sql.shuffle.partitions', '8') \\\n",
    "    .config('spark.ui.showConsoleProgress', 'false') \\\n",
    "    .getOrCreate()\n",
    "\n",
    "spark.sparkContext.setLogLevel('ERROR')  # suppress verbose logs\n",
    "print(f'✅ PySpark version: {spark.version}')\n",
    "print(f'✅ Spark session started')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 3B: Generate Realistic Synthetic Network Traffic\n",
    "# (Mimics CICIDS2017 structure — use real dataset for research)\n",
    "# ============================================================\n",
    "import random\n",
    "from datetime import datetime, timedelta\n",
    "\n",
    "random.seed(42)\n",
    "np.random.seed(42)\n",
    "\n",
    "def generate_network_traffic(n_samples=5000):\n",
    "    \"\"\"\n",
    "    Generate synthetic network traffic mimicking CICIDS2017 features.\n",
    "    In real deployment: replace with actual packet capture via Scapy/PyShark.\n",
    "    Features match CICIDS2017 dataset columns used in published IDS research.\n",
    "    \"\"\"\n",
    "    attack_types = ['BENIGN', 'DoS_Hulk', 'PortScan', 'DDoS',\n",
    "                    'FTP-Patator', 'SSH-Patator', 'Bot', 'Infiltration']\n",
    "\n",
    "    rows = []\n",
    "    base_time = datetime(2026, 1, 1, 8, 0, 0)\n",
    "\n",
    "    for i in range(n_samples):\n",
    "        # 80% benign, 20% attacks (realistic ratio)\n",
    "        label = 'BENIGN' if random.random() < 0.80 else random.choice(attack_types[1:])\n",
    "        is_attack = label != 'BENIGN'\n",
    "\n",
    "        # Feature engineering based on attack type patterns\n",
    "        if label == 'DoS_Hulk':\n",
    "            flow_duration     = random.randint(100, 1000)\n",
    "            fwd_packets       = random.randint(500, 2000)\n",
    "            bwd_packets       = random.randint(0, 10)\n",
    "            fwd_packet_len    = random.randint(1400, 1500)\n",
    "            flow_bytes_s      = random.uniform(100000, 1000000)\n",
    "            flow_packets_s    = random.uniform(1000, 5000)\n",
    "            psh_flags         = random.randint(50, 200)\n",
    "            syn_flags         = random.randint(0, 5)\n",
    "            dst_port          = random.choice([80, 443, 8080])\n",
    "        elif label == 'PortScan':\n",
    "            flow_duration     = random.randint(1, 100)\n",
    "            fwd_packets       = random.randint(1, 3)\n",
    "            bwd_packets       = random.randint(0, 2)\n",
    "            fwd_packet_len    = random.randint(40, 80)\n",
    "            flow_bytes_s      = random.uniform(10, 500)\n",
    "            flow_packets_s    = random.uniform(1, 50)\n",
    "            psh_flags         = 0\n",
    "            syn_flags         = random.randint(1, 3)\n",
    "            dst_port          = random.randint(1, 65535)\n",
    "        elif label == 'DDoS':\n",
    "            flow_duration     = random.randint(50, 500)\n",
    "            fwd_packets       = random.randint(200, 1000)\n",
    "            bwd_packets       = random.randint(0, 5)\n",
    "            fwd_packet_len    = random.randint(800, 1500)\n",
    "            flow_bytes_s      = random.uniform(50000, 500000)\n",
    "            flow_packets_s    = random.uniform(500, 3000)\n",
    "            psh_flags         = random.randint(20, 100)\n",
    "            syn_flags         = random.randint(5, 50)\n",
    "            dst_port          = random.choice([80, 443])\n",
    "        elif label in ['FTP-Patator', 'SSH-Patator']:\n",
    "            flow_duration     = random.randint(1000, 5000)\n",
    "            fwd_packets       = random.randint(5, 30)\n",
    "            bwd_packets       = random.randint(3, 20)\n",
    "            fwd_packet_len    = random.randint(50, 200)\n",
    "            flow_bytes_s      = random.uniform(100, 5000)\n",
    "            flow_packets_s    = random.uniform(1, 20)\n",
    "            psh_flags         = random.randint(2, 10)\n",
    "            syn_flags         = random.randint(1, 5)\n",
    "            dst_port          = 21 if label == 'FTP-Patator' else 22\n",
    "        else:  # BENIGN and others\n",
    "            flow_duration     = random.randint(1000, 100000)\n",
    "            fwd_packets       = random.randint(2, 50)\n",
    "            bwd_packets       = random.randint(1, 40)\n",
    "            fwd_packet_len    = random.randint(100, 800)\n",
    "            flow_bytes_s      = random.uniform(100, 10000)\n",
    "            flow_packets_s    = random.uniform(0.5, 100)\n",
    "            psh_flags         = random.randint(1, 20)\n",
    "            syn_flags         = random.randint(0, 3)\n",
    "            dst_port          = random.choice([80, 443, 22, 53, 8080, 3306])\n",
    "\n",
    "        # Generate source/dest IPs\n",
    "        src_ip = f'192.168.{random.randint(1,5)}.{random.randint(1,254)}'\n",
    "        dst_ip = f'192.168.1.{random.randint(1,10)}' if not is_attack else \\\n",
    "                 f'10.0.0.{random.randint(1,5)}'\n",
    "\n",
    "        rows.append({\n",
    "            'timestamp':          (base_time + timedelta(seconds=i*0.5)).strftime('%Y-%m-%d %H:%M:%S'),\n",
    "            'src_ip':             src_ip,\n",
    "            'dst_ip':             dst_ip,\n",
    "            'src_port':           random.randint(1024, 65535),\n",
    "            'dst_port':           dst_port,\n",
    "            'protocol':           random.choice(['TCP', 'UDP', 'ICMP']),\n",
    "            'flow_duration':      flow_duration,\n",
    "            'fwd_packets':        fwd_packets,\n",
    "            'bwd_packets':        bwd_packets,\n",
    "            'fwd_packet_len_mean': fwd_packet_len,\n",
    "            'bwd_packet_len_mean': random.randint(40, fwd_packet_len),\n",
    "            'flow_bytes_s':       round(flow_bytes_s, 2),\n",
    "            'flow_packets_s':     round(flow_packets_s, 2),\n",
    "            'psh_flag_count':     psh_flags,\n",
    "            'syn_flag_count':     syn_flags,\n",
    "            'ack_flag_count':     random.randint(1, fwd_packets),\n",
    "            'fin_flag_count':     random.randint(0, 3),\n",
    "            'idle_mean':          random.uniform(0, 100000),\n",
    "            'active_mean':        random.uniform(0, 50000),\n",
    "            'label':              label,\n",
    "            'is_attack':          int(is_attack)\n",
    "        })\n",
    "\n",
    "    return pd.DataFrame(rows)\n",
    "\n",
    "# Generate dataset\n",
    "print('⏳ Generating synthetic network traffic dataset...')\n",
    "traffic_df = generate_network_traffic(5000)\n",
    "\n",
    "# Save locally\n",
    "traffic_df.to_csv('/content/network_traffic.csv', index=False)\n",
    "\n",
    "# Load into PySpark for big data processing\n",
    "spark_df = spark.createDataFrame(traffic_df)\n",
    "\n",
    "print(f'✅ Dataset created: {traffic_df.shape[0]:,} records, {traffic_df.shape[1]} features')\n",
    "print(f'\\n📊 Label Distribution:')\n",
    "print(traffic_df['label'].value_counts().to_string())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 3C: PySpark Feature Engineering & Preprocessing\n",
    "# ============================================================\n",
    "print('⚙️  Running PySpark preprocessing pipeline...')\n",
    "\n",
    "# ── Step 1: Basic statistics via Spark ──────────────────────\n",
    "spark_df.createOrReplaceTempView('network_traffic')\n",
    "\n",
    "attack_stats = spark.sql(\"\"\"\n",
    "    SELECT\n",
    "        label,\n",
    "        COUNT(*) as count,\n",
    "        ROUND(AVG(flow_bytes_s), 2) as avg_bytes_per_sec,\n",
    "        ROUND(AVG(flow_packets_s), 2) as avg_pkts_per_sec,\n",
    "        ROUND(AVG(fwd_packets), 2) as avg_fwd_pkts,\n",
    "        ROUND(MAX(flow_bytes_s), 2) as max_bytes_per_sec\n",
    "    FROM network_traffic\n",
    "    GROUP BY label\n",
    "    ORDER BY count DESC\n",
    "\"\"\")\n",
    "\n",
    "print('\\n📊 Traffic Analysis by Category (via PySpark SQL):')\n",
    "attack_stats.show(truncate=False)\n",
    "\n",
    "# ── Step 2: Feature engineering in Spark ────────────────────\n",
    "spark_df_enriched = spark_df.withColumn(\n",
    "    'packet_ratio',\n",
    "    F.when(F.col('bwd_packets') > 0,\n",
    "           F.col('fwd_packets') / F.col('bwd_packets')\n",
    "    ).otherwise(F.lit(999.0))\n",
    ").withColumn(\n",
    "    'bytes_per_packet',\n",
    "    F.when(F.col('fwd_packets') + F.col('bwd_packets') > 0,\n",
    "           F.col('flow_bytes_s') / (F.col('fwd_packets') + F.col('bwd_packets'))\n",
    "    ).otherwise(F.lit(0.0))\n",
    ").withColumn(\n",
    "    'flag_ratio',\n",
    "    F.col('syn_flag_count') / (F.col('ack_flag_count') + F.lit(1))\n",
    ").withColumn(\n",
    "    'is_common_port',\n",
    "    F.when(F.col('dst_port').isin([80, 443, 22, 21, 53, 3306, 8080]), 1).otherwise(0)\n",
    ")\n",
    "\n",
    "# Convert to Pandas for sklearn (Spark does feature engineering at scale)\n",
    "processed_df = spark_df_enriched.toPandas()\n",
    "\n",
    "print(f'✅ PySpark processing complete: {len(processed_df):,} records processed')\n",
    "print(f'✅ New engineered features: packet_ratio, bytes_per_packet, flag_ratio, is_common_port')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 🤖 STEP 4: Machine Learning Models\n",
    "*Two-tier detection: Unsupervised (Isolation Forest) + Supervised (Random Forest)*"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 4: Train ML Models (Scikit-learn)\n",
    "# ============================================================\n",
    "from sklearn.ensemble import IsolationForest, RandomForestClassifier\n",
    "from sklearn.preprocessing import StandardScaler, LabelEncoder\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.metrics import classification_report, confusion_matrix, roc_auc_score\n",
    "import joblib\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# ── Feature selection ─────────────────────────────────────────\n",
    "FEATURE_COLS = [\n",
    "    'flow_duration', 'fwd_packets', 'bwd_packets',\n",
    "    'fwd_packet_len_mean', 'bwd_packet_len_mean',\n",
    "    'flow_bytes_s', 'flow_packets_s',\n",
    "    'psh_flag_count', 'syn_flag_count', 'ack_flag_count', 'fin_flag_count',\n",
    "    'idle_mean', 'active_mean',\n",
    "    'packet_ratio', 'bytes_per_packet', 'flag_ratio', 'is_common_port'\n",
    "]\n",
    "\n",
    "X = processed_df[FEATURE_COLS].fillna(0)\n",
    "y_binary  = processed_df['is_attack']\n",
    "y_multiclass = processed_df['label']\n",
    "\n",
    "# ── Normalize features ────────────────────────────────────────\n",
    "scaler = StandardScaler()\n",
    "X_scaled = scaler.fit_transform(X)\n",
    "\n",
    "# ── Train/test split ─────────────────────────────────────────\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X_scaled, y_binary, test_size=0.2, random_state=42, stratify=y_binary\n",
    ")\n",
    "\n",
    "print('=' * 60)\n",
    "print('   MODEL 1: Isolation Forest (Unsupervised — No Labels Needed)')\n",
    "print('=' * 60)\n",
    "\n",
    "# Train Isolation Forest on BENIGN traffic only (realistic IDS scenario)\n",
    "X_benign = X_scaled[y_binary == 0]\n",
    "iso_forest = IsolationForest(\n",
    "    n_estimators=200,\n",
    "    contamination=0.05,  # expected ~5% anomalies\n",
    "    random_state=42,\n",
    "    n_jobs=-1\n",
    ")\n",
    "iso_forest.fit(X_benign)\n",
    "\n",
    "# Predict: -1 = anomaly, 1 = normal → convert to 1/0\n",
    "iso_preds = (iso_forest.predict(X_scaled) == -1).astype(int)\n",
    "iso_scores = -iso_forest.score_samples(X_scaled)  # higher = more anomalous\n",
    "\n",
    "# Evaluate\n",
    "from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score\n",
    "print(f'  Accuracy:  {accuracy_score(y_binary, iso_preds):.4f}')\n",
    "print(f'  Precision: {precision_score(y_binary, iso_preds, zero_division=0):.4f}')\n",
    "print(f'  Recall:    {recall_score(y_binary, iso_preds, zero_division=0):.4f}')\n",
    "print(f'  F1-Score:  {f1_score(y_binary, iso_preds, zero_division=0):.4f}')\n",
    "\n",
    "print('\\n' + '=' * 60)\n",
    "print('   MODEL 2: Random Forest (Supervised — Multi-class Detection)')\n",
    "print('=' * 60)\n",
    "\n",
    "# Train Random Forest\n",
    "rf_classifier = RandomForestClassifier(\n",
    "    n_estimators=200,\n",
    "    max_depth=15,\n",
    "    min_samples_split=5,\n",
    "    random_state=42,\n",
    "    n_jobs=-1,\n",
    "    class_weight='balanced'\n",
    ")\n",
    "\n",
    "# Multi-class labels\n",
    "le = LabelEncoder()\n",
    "y_encoded = le.fit_transform(y_multiclass)\n",
    "X_tr, X_te, y_tr, y_te = train_test_split(\n",
    "    X_scaled, y_encoded, test_size=0.2, random_state=42, stratify=y_encoded\n",
    ")\n",
    "\n",
    "rf_classifier.fit(X_tr, y_tr)\n",
    "rf_preds    = rf_classifier.predict(X_te)\n",
    "rf_proba    = rf_classifier.predict_proba(X_te)\n",
    "\n",
    "print(classification_report(\n",
    "    y_te, rf_preds,\n",
    "    target_names=le.classes_,\n",
    "    zero_division=0\n",
    "))\n",
    "\n",
    "# Feature importance\n",
    "importances = pd.Series(rf_classifier.feature_importances_, index=FEATURE_COLS)\n",
    "print('\\n🔍 Top 5 Most Important Features:')\n",
    "print(importances.sort_values(ascending=False).head(5).to_string())\n",
    "\n",
    "# Save models\n",
    "joblib.dump(iso_forest,    '/content/iso_forest_model.pkl')\n",
    "joblib.dump(rf_classifier, '/content/rf_classifier_model.pkl')\n",
    "joblib.dump(scaler,        '/content/feature_scaler.pkl')\n",
    "joblib.dump(le,            '/content/label_encoder.pkl')\n",
    "\n",
    "print('\\n✅ Models trained and saved!')\n",
    "\n",
    "# Save results for dashboard\n",
    "processed_df['iso_prediction']     = iso_preds\n",
    "processed_df['iso_anomaly_score']  = iso_scores\n",
    "processed_df.to_csv('/content/processed_traffic.csv', index=False)"
   ]
  },
  {
