    "---\n",
    "## 📚 STEP 5: RAG-Based Threat Knowledge Base\n",
    "*Stores threat intelligence; retrieved as context for LLM analysis*"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 5: Build RAG Threat Knowledge Base\n",
    "# ============================================================\n",
    "import faiss\n",
    "import numpy as np\n",
    "from sentence_transformers import SentenceTransformer\n",
    "import pickle\n",
    "import json\n",
    "\n",
    "# ── Threat knowledge base documents ──────────────────────────\n",
    "# In real deployment: ingest MITRE ATT&CK, CVE database, Snort rules\n",
    "THREAT_KNOWLEDGE_BASE = [\n",
    "    {\n",
    "        \"id\": \"T001\",\n",
    "        \"attack_type\": \"DoS_Hulk\",\n",
    "        \"title\": \"HTTP Hulk DoS Attack\",\n",
    "        \"description\": \"Hulk generates unique HTTP GET requests rapidly to overwhelm web servers. Characteristics: very high flow bytes per second (>100,000), extremely high forward packet count (>500), minimal backward packets, PSH flag dominance, target ports 80/443/8080.\",\n",
    "        \"mitre_technique\": \"T1498.001 - Direct Network Flood\",\n",
    "        \"severity\": \"CRITICAL\",\n",
    "        \"indicators\": \"flow_bytes_s > 100000, fwd_packets > 500, dst_port in [80,443,8080]\",\n",
    "        \"mitigation\": \"Rate limiting, CDN protection, IP blacklisting, WAF rules. Deploy Cloudflare or AWS Shield for large-scale attacks.\",\n",
    "        \"cvss_score\": 8.6\n",
    "    },\n",
    "    {\n",
    "        \"id\": \"T002\",\n",
    "        \"attack_type\": \"PortScan\",\n",
    "        \"title\": \"Network Port Scanning\",\n",
    "        \"description\": \"Systematic probing of network ports to discover open services. Characteristics: very short flow duration (<100ms), 1-3 packets per flow, high SYN flags, sequential port numbers, low bytes per flow, single source IP targeting multiple ports.\",\n",
    "        \"mitre_technique\": \"T1046 - Network Service Discovery\",\n",
    "        \"severity\": \"HIGH\",\n",
    "        \"indicators\": \"flow_duration < 100, fwd_packets < 3, syn_flag_count > 0, random dst_port\",\n",
    "        \"mitigation\": \"Deploy port knocking, firewall rules blocking sequential scans, IPS signatures, honeypot ports. Monitor for multiple connection attempts from single source.\",\n",
    "        \"cvss_score\": 5.3\n",
    "    },\n",
    "    {\n",
    "        \"id\": \"T003\",\n",
    "        \"attack_type\": \"DDoS\",\n",
    "        \"title\": \"Distributed Denial of Service\",\n",
    "        \"description\": \"Coordinated flood from multiple sources to exhaust target resources. Characteristics: massive traffic volume from multiple source IPs, high SYN flags (SYN flood variant), asymmetric traffic pattern, packet sizes near MTU (1500 bytes).\",\n",
    "        \"mitre_technique\": \"T1498 - Network Denial of Service\",\n",
    "        \"severity\": \"CRITICAL\",\n",
    "        \"indicators\": \"Multiple source IPs, flow_packets_s > 500, syn_flag_count elevated, fwd_packet_len near 1500\",\n",
    "        \"mitigation\": \"Anycast network diffusion, traffic scrubbing centers, BGP blackholing, upstream ISP filtering. Implement BCP38 to prevent IP spoofing.\",\n",
    "        \"cvss_score\": 9.1\n",
    "    },\n",
    "    {\n",
    "        \"id\": \"T004\",\n",
    "        \"attack_type\": \"FTP-Patator\",\n",
    "        \"title\": \"FTP Brute Force (Patator)\",\n",
    "        \"description\": \"Automated credential brute-forcing against FTP service on port 21. Characteristics: port 21 destination, repeated connection attempts, moderate packet counts with balanced bidirectional flow, consistent packet sizes (FTP banner + credentials).\",\n",
    "        \"mitre_technique\": \"T1110.001 - Brute Force: Password Guessing\",\n",
    "        \"severity\": \"HIGH\",\n",
    "        \"indicators\": \"dst_port == 21, repeated connections from same source, bwd_packets moderate (FTP responses)\",\n",
    "        \"mitigation\": \"Account lockout policies, fail2ban, CAPTCHA, certificate-based authentication. Disable FTP; use SFTP instead. Monitor failed login rates.\",\n",
    "        \"cvss_score\": 7.5\n",
    "    },\n",
    "    {\n",
    "        \"id\": \"T005\",\n",
    "        \"attack_type\": \"SSH-Patator\",\n",
    "        \"title\": \"SSH Brute Force (Patator)\",\n",
    "        \"description\": \"Automated brute-force attack against SSH service (port 22). Characteristics: destination port 22, multiple failed authentication attempts, moderate bidirectional traffic, slower than FTP-Patator due to SSH handshake overhead.\",\n",
    "        \"mitre_technique\": \"T1110.001 - Brute Force: Password Guessing\",\n",
    "        \"severity\": \"HIGH\",\n",
    "        \"indicators\": \"dst_port == 22, flow_duration moderate (SSH handshake cost), repeated from same src_ip\",\n",
    "        \"mitigation\": \"Key-based authentication only, fail2ban with aggressive rules, port knocking, two-factor authentication. Move SSH to non-standard port and restrict access via firewall.\",\n",
    "        \"cvss_score\": 7.8\n",
    "    },\n",
    "    {\n",
    "        \"id\": \"T006\",\n",
    "        \"attack_type\": \"Bot\",\n",
    "        \"title\": \"Botnet Command & Control Traffic\",\n",
    "        \"description\": \"Infected hosts communicating with C2 servers. Characteristics: periodic beaconing intervals, small consistent packet sizes, unusual destination IPs/ports, encrypted traffic to uncommon ports, low but consistent flow rates.\",\n",
    "        \"mitre_technique\": \"T1071 - Application Layer Protocol (C2)\",\n",
    "        \"severity\": \"CRITICAL\",\n",
    "        \"indicators\": \"Regular beaconing intervals, small packet sizes, unusual dst_ip ranges, encrypted communications\",\n",
    "        \"mitigation\": \"DNS sinkholing, threat intelligence feed blocking, egress filtering, endpoint detection and response (EDR). Implement zero-trust network architecture.\",\n",
    "        \"cvss_score\": 8.8\n",
    "    },\n",
    "    {\n",
    "        \"id\": \"T007\",\n",
    "        \"attack_type\": \"Infiltration\",\n",
    "        \"title\": \"Network Infiltration / Lateral Movement\",\n",
    "        \"description\": \"Attacker moving within the network after initial compromise. Characteristics: traffic between internal subnets, use of legitimate protocols (SMB, RDP, WMI), abnormal access patterns, access to unusual resources.\",\n",
    "        \"mitre_technique\": \"T1021 - Remote Services (Lateral Movement)\",\n",
    "        \"severity\": \"CRITICAL\",\n",
    "        \"indicators\": \"Internal-to-internal unusual traffic, protocol anomalies, access to admin shares, abnormal user behavior\",\n",
    "        \"mitigation\": \"Network segmentation, micro-segmentation, privileged access workstations (PAW), user behavior analytics (UBA). Implement least privilege access control.\",\n",
    "        \"cvss_score\": 9.3\n",
    "    },\n",
    "    {\n",
    "        \"id\": \"T008\",\n",
    "        \"attack_type\": \"BENIGN\",\n",
    "        \"title\": \"Normal Network Traffic Baseline\",\n",
    "        \"description\": \"Legitimate network traffic patterns. Characteristics: balanced bidirectional flow, typical packet sizes (100-1000 bytes), standard protocols on common ports, consistent timing patterns, reasonable flow rates.\",\n",
    "        \"mitre_technique\": \"N/A\",\n",
    "        \"severity\": \"NONE\",\n",
    "        \"indicators\": \"Balanced fwd/bwd packets, standard ports (80,443,53,22), normal flow_bytes_s (<10000)\",\n",
    "        \"mitigation\": \"N/A - continue monitoring\",\n",
    "        \"cvss_score\": 0.0\n",
    "    }\n",
    "]\n",
    "\n",
    "# ── Build FAISS vector index ──────────────────────────────────\n",
    "print('⏳ Loading sentence transformer (this takes ~1 minute on first run)...')\n",
    "encoder = SentenceTransformer('all-MiniLM-L6-v2')  # fast & accurate, 384-dim\n",
    "\n",
    "# Encode knowledge documents\n",
    "doc_texts = []\n",
    "for doc in THREAT_KNOWLEDGE_BASE:\n",
    "    text = f\"{doc['title']}. {doc['description']} Indicators: {doc['indicators']}. Mitigation: {doc['mitigation']}\"\n",
    "    doc_texts.append(text)\n",
    "\n",
    "print('⚙️  Encoding threat knowledge base...')\n",
    "embeddings = encoder.encode(doc_texts, show_progress_bar=False)\n",
    "embeddings = np.array(embeddings).astype('float32')\n",
    "\n",
    "# Normalize for cosine similarity\n",
    "faiss.normalize_L2(embeddings)\n",
    "\n",
    "# Build FAISS index (Inner Product = Cosine Similarity after normalization)\n",
    "dimension = embeddings.shape[1]  # 384\n",
    "faiss_index = faiss.IndexFlatIP(dimension)\n",
    "faiss_index.add(embeddings)\n",
    "\n",
    "# Save artifacts\n",
    "faiss.write_index(faiss_index, '/content/threat_kb.faiss')\n",
    "with open('/content/threat_kb_docs.pkl', 'wb') as f:\n",
    "    pickle.dump(THREAT_KNOWLEDGE_BASE, f)\n",
    "with open('/content/threat_kb_texts.pkl', 'wb') as f:\n",
    "    pickle.dump(doc_texts, f)\n",
    "\n",
    "print(f'✅ Knowledge Base built: {len(THREAT_KNOWLEDGE_BASE)} threat documents indexed')\n",
    "print(f'✅ Vector dimension: {dimension}')\n",
    "print(f'✅ Total vectors in FAISS index: {faiss_index.ntotal}')\n",
    "\n",
    "# ── Test retrieval ────────────────────────────────────────────\n",
    "def retrieve_threat_context(query, top_k=2):\n",
    "    \"\"\"Retrieve relevant threat intelligence for a given network flow description.\"\"\"\n",
    "    query_vec = encoder.encode([query]).astype('float32')\n",
    "    faiss.normalize_L2(query_vec)\n",
    "    distances, indices = faiss_index.search(query_vec, top_k)\n",
    "    results = []\n",
    "    for dist, idx in zip(distances[0], indices[0]):\n",
    "        if idx >= 0:\n",
    "            doc = THREAT_KNOWLEDGE_BASE[idx].copy()\n",
    "            doc['similarity'] = float(dist)\n",
    "            results.append(doc)\n",
    "    return results\n",
    "\n",
    "# Test\n",
    "test_query = 'high traffic volume port 80 many packets per second'\n",
    "results = retrieve_threat_context(test_query)\n",
    "print(f'\\n🔍 Test Query: \"{test_query}\"')\n",
    "print(f'   Top match: {results[0][\"title\"]} (similarity: {results[0][\"similarity\"]:.3f})')"
   ]
  },
